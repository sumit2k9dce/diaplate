# DiaPlate Environment Variables — copy to .env.local

# Twilio (free sandbox: https://console.twilio.com/us1/develop/sms/try-it-out/whatsapp-learn)
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Google AI Studio — Gemini Flash (free: https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key

# Supabase (free: https://supabase.com/dashboard)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key

# Cron secret (Vercel auto-sets this for cron jobs, or set any random string)
CRON_SECRET=your_random_secret_string
